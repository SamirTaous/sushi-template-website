# Environment Variables for Multi-Brand Restaurant Template

# Default brand to use when no brand is specified
DEFAULT_BRAND=tobiko

# Domain mapping (JSON format)
# Maps custom domains to brand keys
DOMAIN_MAPPING={"tobiko.com":"tobiko","sakura-restaurant.com":"sakura"}

# Analytics and tracking
VERCEL_ANALYTICS_ID=
GOOGLE_ANALYTICS_ID=

# Email configuration for contact forms
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# Database (if needed for reservations/orders)
DATABASE_URL=

# External service integrations
UBEREATS_API_KEY=
DELIVEROO_API_KEY=
GOOGLE_MAPS_API_KEY=

# Feature flags
ENABLE_RESERVATIONS=true
ENABLE_ONLINE_ORDERING=true
ENABLE_ANALYTICS=true

# Brand-specific overrides (optional)
# Use these to override specific brand configurations via environment
TOBIKO_PHONE_OVERRIDE=
SAKURA_PHONE_OVERRIDE=